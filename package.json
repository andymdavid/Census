{
  "name": "census",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.2",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "framer-motion": "^12.5.0",
    "lucide-react": "^0.563.0",
    "nostr-tools": "^2.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.3.0",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "PORT=3002 bun run server/server.ts",
    "build": "vite build",
    "start": "bun run server/server.ts",
    "start:local": "PORT=3002 bun run server/server.ts",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:server",
    "test:unit": "vitest run",
    "test:browser": "vitest run",
    "test:public-flow": "vitest run src/publicFormFlow.test.tsx",
    "test:server": "bun test server/apiRoutes.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.3.0",
    "vite": "^5.4.14",
    "vitest": "^4.1.4"
  }
}
